      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "type_base_size",
        "label": "Base font size (px)",
        "min": 14,
        "max": 18,
        "step": 1,
        "default": 16
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
