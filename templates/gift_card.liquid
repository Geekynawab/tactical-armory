<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ 'gift_cards.issued' | t }} — {{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--color-bg-primary)">
    <div style="max-width:480px;width:100%;text-align:center;padding:2rem">

      <div style="font-family:var(--font-headline);font-weight:900;font-size:1.5rem;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:2rem">
        <span style="color:var(--color-accent)">VALORANT</span> MERCH
      </div>

      <div style="background:linear-gradient(135deg,var(--color-accent),var(--color-accent-hover));padding:2.5rem;margin-bottom:2rem;clip-path:polygon(0 0,calc(100% - 16px) 0,100% 16px,100% 100%,16px 100%,0 calc(100% - 16px))">
        <p style="font-size:0.75rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.7);margin-bottom:0.5rem">Gift Card</p>
        <p style="font-size:2.5rem;font-weight:900;color:#fff;letter-spacing:0.05em">{{ gift_card.initial_value | money_without_trailing_zeros }}</p>
        <p style="font-size:0.75rem;color:rgba(255,255,255,0.7);margin-top:0.5rem">{{ shop.name }}</p>
      </div>

      <div style="background:var(--color-bg-secondary);border:1px solid var(--color-border);padding:1.5rem;margin-bottom:1.5rem">
        <p style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.5rem">Gift Card Code</p>
        <p id="gift-card-code" style="font-size:1.25rem;font-weight:700;letter-spacing:0.15em;color:var(--color-text-primary);font-family:monospace">{{ gift_card.code | format_code }}</p>
      </div>

      <p style="font-size:0.82rem;color:var(--color-text-secondary);margin-bottom:1rem">
        {{ 'gift_cards.remaining_html' | t: balance: gift_card.balance | money }}
      </p>

      {%- if gift_card.expires_on -%}
        <p style="font-size:0.75rem;color:var(--color-text-muted);margin-bottom:1.5rem">
          {{ 'gift_cards.subtext' | t: expiry: gift_card.expires_on | date: '%B %d, %Y' }}
        </p>
      {%- endif -%}

      <a href="{{ shop.url }}" class="btn btn--primary">
        Shop Now
      </a>

    </div>
  </body>
</html>
