{%- assign blog_handle = section.settings.blog | default: 'news' -%}
{%- assign preview_blog = blogs[blog_handle] -%}

{%- if preview_blog.articles.size > 0 -%}
<section class="section blog-preview">
  <div class="container">

    <div class="section-header">
      <div class="section-header__title-wrap">
        {%- if section.settings.eyebrow != blank -%}
          <p class="section-subtitle">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="section-title">{{ section.settings.heading | default: 'Latest News' }}</h2>
        <span class="section-divider"></span>
      </div>
      <a href="{{ preview_blog.url }}" class="btn btn--outline btn--sm">View All</a>
    </div>

    <div class="blog-preview__grid">
      {%- for article in preview_blog.articles limit: section.settings.posts_to_show -%}
        <a href="{{ article.url }}" class="blog-card">
          {%- if article.image != blank -%}
            <div class="blog-card__image">
              <img
                src="{{ article.image | image_url: width: 600 }}"
                alt="{{ article.image.alt | default: article.title | escape }}"
                loading="lazy"
                width="600"
                height="340">
            </div>
          {%- endif -%}
          <div class="blog-card__body">
            {%- if article.tags.size > 0 -%}
              <p class="blog-card__tag">{{ article.tags.first }}</p>
            {%- endif -%}
            <h3 class="blog-card__title">{{ article.title }}</h3>
            <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 100 }}</p>
            <span class="blog-card__cta">Read More →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Blog Preview",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the vault" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "LATEST NEWS" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "posts_to_show", "label": "Posts to show", "min": 2, "max": 4, "step": 1, "default": 3 }
  ],
  "presets": [
    {
      "name": "Blog Preview",
      "settings": { "eyebrow": "From the vault", "heading": "LATEST NEWS", "posts_to_show": 3 }
    }
  ]
}
{% endschema %}
