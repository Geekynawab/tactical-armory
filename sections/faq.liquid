<section class="section faq-section">
  <div class="container">

    {%- if section.settings.eyebrow != blank -%}
      <p class="section-subtitle">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 class="section-title">{{ section.settings.heading | default: 'FAQ' }}</h2>
    <span class="section-divider"></span>

    <div class="faq-list">
      {%- for block in section.blocks -%}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-item__question" aria-expanded="false">
            <span>{{ block.settings.question }}</span>
            <svg class="faq-item__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="faq-item__answer" hidden>
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
(function () {
  var faqList = document.querySelectorAll('.faq-item__question');
  faqList.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var answer  = btn.nextElementSibling;
      var isOpen  = btn.getAttribute('aria-expanded') === 'true';
      // Close all
      faqList.forEach(function (b) {
        b.setAttribute('aria-expanded', 'false');
        b.nextElementSibling.hidden = true;
      });
      // Toggle clicked
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        answer.hidden = false;
      }
    });
  });
}());
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Got Questions?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "FAQ" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Are these real knives?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Yes — these are physical, real-steel replicas of Valorant weapon skins, crafted for collectors and fans. Always handle with care." }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "settings": { "eyebrow": "Got Questions?", "heading": "FAQ" },
      "blocks": [
        { "type": "question", "settings": { "question": "Are these real knives?", "answer": "Yes — these are physical, real-steel replicas of Valorant weapon skins, crafted for collectors and fans. Always handle with care and follow local laws." } },
        { "type": "question", "settings": { "question": "How long does shipping take?", "answer": "We ship same-day on weekdays. Delivery typically takes 3–7 business days depending on your location. We ship to 30+ countries worldwide." } },
        { "type": "question", "settings": { "question": "What is your return policy?", "answer": "We offer a 30-day return window. Items must be unused and in original packaging. Contact support to initiate a return." } },
        { "type": "question", "settings": { "question": "Are these officially licensed by Riot Games?", "answer": "No — these are fan-made replicas and are not affiliated with or endorsed by Riot Games or VALORANT." } },
        { "type": "question", "settings": { "question": "Is there an age requirement?", "answer": "Yes. You must be 18 or older to purchase knife products. By completing your purchase you confirm you meet the age requirement in your jurisdiction." } }
      ]
    }
  ]
}
{% endschema %}
