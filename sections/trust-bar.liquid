<section class="trust-bar">
  <div class="container">
    <div class="trust-bar__grid">

      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <h3 class="trust-bar__title">Worldwide shipping</h3>
        <p class="trust-bar__text">We deliver fast and at the best price in more than 30 countries</p>
      </div>

      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h3 class="trust-bar__title">Fast Dispatch</h3>
        <p class="trust-bar__text">All orders are packed and shipped within 1–3 business days</p>
      </div>

      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polyline points="1 4 1 10 7 10"/>
            <path d="M3.51 15a9 9 0 1 0 .49-3.67"/>
          </svg>
        </div>
        <h3 class="trust-bar__title">Returns within 30 days</h3>
        <p class="trust-bar__text">You have up to one month to change your mind and return your product</p>
      </div>

    </div>
  </div>
</section>

{% schema %}
