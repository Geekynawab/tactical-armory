{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign sticky_inflated = current_variant.price | times: 1.3 | ceil -%}

<!-- Sticky ATC bar -->
<div class="sticky-atc" id="sticky-atc" aria-hidden="true">
  <div class="container">
    <div class="sticky-atc__inner">
      <div class="sticky-atc__info">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.title | escape }}" width="40" height="40" class="sticky-atc__img">
        {%- endif -%}
        <div class="sticky-atc__text">
          <span class="sticky-atc__title">{{ product.title }}</span>
          <span class="sticky-atc__price">
            <span class="sale">{{ current_variant.price | money }}</span>
            <span class="compare-at">{{ sticky_inflated | money }}</span>
          </span>
        </div>
      </div>
      <button class="btn btn--primary sticky-atc__btn" id="sticky-atc-btn"
        {%- unless current_variant.available %} disabled{%- endunless -%}>
        {%- if current_variant.available -%}Add to Arsenal{%- else -%}Sold Out{%- endif -%}
      </button>
    </div>
  </div>
</div>

<!-- Main product layout -->
<div class="product-page">
  <div class="container">
    <div class="product-layout">

      <!-- LEFT: Sticky gallery -->
      <div class="product-layout__gallery">
        <div class="product-gallery{% if product.images.size <= 1 %} product-gallery--single{% endif %}">

          {%- if product.images.size > 1 -%}
            <div class="product-gallery__thumbs">
              {%- for image in product.images limit: 8 -%}
                <button
                  class="product-gallery__thumb{% if forloop.first %} active{% endif %}"
                  data-src="{{ image | image_url: width: 900 }}"
                  aria-label="View image {{ forloop.index }}">
                  <img
                    src="{{ image | image_url: width: 120 }}"
                    alt="{{ image.alt | default: product.title | escape }}"
                    width="120"
                    height="120"
                    loading="lazy">
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="product-gallery__main">
            {%- if product.featured_image != blank -%}
              <img
                id="gallery-main-img"
                src="{{ product.featured_image | image_url: width: 900 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                loading="eager"
                width="900"
                height="900"
                data-inspect-src="{{ product.featured_image | image_url: width: 1600 }}">
              <button class="product-gallery__inspect-btn" data-open-inspect aria-label="Inspect full screen">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
                INSPECT
              </button>
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'product-gallery__placeholder' }}
            {%- endif -%}
          </div>

        </div>
      </div>

      <!-- RIGHT: Scrollable info -->
      <div class="product-layout__info">

        <!-- Category tags -->
        {%- if collection or product.type != blank -%}
          <div class="product-info__tags">
            {%- if collection -%}<span>{{ collection.title }}</span>{%- endif -%}
            {%- if product.type != blank -%}<span class="tag-sep">|</span><span>{{ product.type }}</span>{%- endif -%}
          </div>
        {%- endif -%}

        <!-- Title -->
        <div class="product-info__title-row">
          <h1 class="product-info__title">{{ product.title }}</h1>
        </div>

        <!-- HUD stat chips -->
        <div class="product-hud-chips">
          {%- if product.type != blank -%}
            <span class="hud-chip">{{ product.type | upcase }}</span>
          {%- endif -%}
          {%- if product.vendor != blank -%}
            <span class="hud-chip">{{ product.vendor | upcase }}</span>
          {%- endif -%}
          {%- assign weight_g = product.variants.first.weight -%}
          {%- if weight_g and weight_g > 0 -%}
            <span class="hud-chip">{{ weight_g }}G</span>
          {%- endif -%}
          {%- if product.available -%}
            <span class="hud-chip hud-chip--teal">IN STOCK</span>
          {%- else -%}
            <span class="hud-chip hud-chip--red">SOLD OUT</span>
          {%- endif -%}
          {%- for tag in product.tags limit: 3 -%}
            {%- unless tag == 'new' or tag == 'sale' -%}
              <span class="hud-chip">{{ tag | upcase }}</span>
            {%- endunless -%}
          {%- endfor -%}
        </div>

        <!-- Price -->
        <div class="product-info__price" id="product-price">
          {%- assign inflated = current_variant.price | times: 1.3 | ceil -%}
          <span class="sale">{{ current_variant.price | money }}</span>
          <span class="compare-at">{{ inflated | money }}</span>
        </div>

        <!-- Bulk savings -->
        {%- assign price_2 = current_variant.price | times: 0.85 | ceil -%}
        {%- assign price_3 = current_variant.price | times: 0.75 | ceil -%}
        <div class="bulk-savings" id="bulk-savings"
          data-price-1="{{ current_variant.price }}"
          data-price-2="{{ price_2 }}"
          data-price-3="{{ price_3 }}">
          <p class="bulk-savings__label">Bulk savings:</p>
          <div class="bulk-savings__tiers">
            <button class="bulk-tier active" data-qty="1" type="button">
              <span class="bulk-tier__qty">Buy 1</span>
              <span class="bulk-tier__price">{{ current_variant.price | money }}/ea</span>
            </button>
            <button class="bulk-tier" data-qty="2" type="button">
              <span class="bulk-tier__qty">Buy 2</span>
              <span class="bulk-tier__price">{{ price_2 | money }}/ea <em>–15%</em></span>
            </button>
            <button class="bulk-tier" data-qty="3" type="button">
              <span class="bulk-tier__qty">Buy 3</span>
              <span class="bulk-tier__price">{{ price_3 | money }}/ea <em>–25%</em></span>
            </button>
          </div>
        </div>

        <hr class="product-info__divider">

        <!-- Variant JSON for JS -->
        <script id="product-variants-json" type="application/json">
          [
            {%- for variant in product.variants -%}
              {
                "id": {{ variant.id }},
                "title": {{ variant.title | json }},
                "price": {{ variant.price }},
                "compare_at_price": {{ variant.compare_at_price | default: 0 }},
                "available": {{ variant.available }},
                "options": [
                  {%- for opt in variant.options -%}
                    {{ opt | json }}{%- unless forloop.last -%},{%- endunless -%}
                  {%- endfor -%}
                ]
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        </script>

        <!-- Variant selectors -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="variant-group" data-variant-group="{{ forloop.index0 }}">
              <p class="variant-label">{{ option.name }} <strong>{{ option.selected_value }}</strong></p>
              <div class="variant-buttons">
                {%- for value in option.values -%}
                  <button
                    class="variant-btn{% if option.selected_value == value %} active{% endif %}"
                    data-option-value="{{ value | escape }}"
                    data-option-index="{{ forloop.parentloop.index0 }}">
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <!-- In stock / low stock indicator -->
        {%- if current_variant.available -%}
          {%- if current_variant.inventory_management != blank and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 10 -%}
            <div class="low-stock-badge">
              <span class="low-stock-badge__dot"></span>
              Only {{ current_variant.inventory_quantity }} left!
            </div>
          {%- else -%}
            <div class="in-stock-badge">
              <span class="in-stock-badge__dot"></span>
              In Stock
            </div>
          {%- endif -%}
        {%- endif -%}

        <!-- Add to cart -->
        {% form 'product', product, data-add-to-cart-form: '' %}
          <input type="hidden" name="id" id="variant-id-input" value="{{ current_variant.id }}">
          <div class="product-info__add-to-cart">
            <div class="product-info__qty">
              <button type="button" onclick="var i=this.nextElementSibling;i.value=Math.max(1,+i.value-1)">−</button>
              <input type="number" name="quantity" value="1" min="1" max="99" aria-label="Quantity">
              <button type="button" onclick="var i=this.previousElementSibling;i.value=Math.min(99,+i.value+1)">+</button>
            </div>
            <button
              type="submit"
              class="btn btn--primary"
              style="flex:1"
              {%- unless current_variant.available %} disabled{%- endunless -%}>
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>
        {% endform %}

        <!-- In carts indicator -->
        <div class="in-carts-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <span><strong id="in-carts-count">—</strong> people have this in their cart right now</span>
        </div>

        <!-- Trust badges -->
        <div class="trust-badges">
          <div class="trust-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Secure checkout
          </div>
          <div class="trust-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            30-day returns
          </div>
        </div>

        <hr class="product-info__divider">

        <!-- Description -->
        {%- if product.description != blank -%}
          <div class="product-info__description">
            <p class="product-info__description-label">Description</p>
            {{ product.description }}
          </div>
        {%- endif -%}

        <!-- Shop the Collection -->
        {%- if collection and collection.products_count > 1 -%}
          <div class="product-related">
            <p class="product-related__label">Shop the Collection</p>
            <div class="product-related__scroll">
              {%- for p in collection.products limit: 6 -%}
                {%- unless p.id == product.id -%}
                  <a href="{{ p.url }}" class="product-related__item">
                    {%- if p.featured_image -%}
                      <img src="{{ p.featured_image | image_url: width: 120 }}" alt="{{ p.title | escape }}" width="60" height="60" loading="lazy">
                    {%- endif -%}
                    <div>
                      <span class="product-related__title">{{ p.title | truncate: 24 }}</span>
                      <span class="product-related__price">{{ p.price | money }}</span>
                    </div>
                  </a>
                {%- endunless -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</div>

<!-- Full-width image slideshow -->
{%- if product.images.size > 1 -%}
<div class="product-slideshow" id="product-slideshow">
  <div class="product-slideshow__track" id="product-slideshow-track">
    {%- for image in product.images -%}
      <div class="product-slideshow__slide">
        <img
          src="{{ image | image_url: width: 900 }}"
          alt="{{ image.alt | default: product.title | escape }}"
          loading="lazy"
          width="900">
      </div>
    {%- endfor -%}
  </div>
  <button class="product-slideshow__btn product-slideshow__btn--prev" id="slideshow-prev" aria-label="Previous image">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="product-slideshow__btn product-slideshow__btn--next" id="slideshow-next" aria-label="Next image">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
</div>
{%- endif -%}

<!-- Recently Viewed -->
<div class="recently-viewed" id="recently-viewed" style="display:none">
  <div class="container">
    <p class="recently-viewed__label">Recently Viewed</p>
    <div class="recently-viewed__grid" id="recently-viewed-grid"></div>
  </div>
</div>

<script>
  window.__currentProduct = {
    id: {{ product.id }},
    title: {{ product.title | json }},
    url: {{ product.url | json }},
    price: {{ product.price }},
    image: {{ product.featured_image | image_url: width: 400 | json }}
  };
</script>

<!-- Inspect Lightbox -->
<div class="inspect-lightbox" id="inspect-lightbox" role="dialog" aria-modal="true" aria-label="Product inspect view" hidden>
  <div class="inspect-lightbox__backdrop" data-close-inspect></div>
  <div class="inspect-lightbox__inner">
    <button class="inspect-lightbox__close" data-close-inspect aria-label="Close inspect">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <img class="inspect-lightbox__img" src="" alt="{{ product.title | escape }}" id="inspect-img">
    <p class="inspect-lightbox__label">{{ product.title | upcase }}</p>
  </div>
</div>

<script>
(function () {
  var lightbox  = document.getElementById('inspect-lightbox');
  var lbImg     = document.getElementById('inspect-img');
  var openBtn   = document.querySelector('[data-open-inspect]');
  var mainImg   = document.getElementById('gallery-main-img');
  if (!lightbox || !openBtn) return;

  function open() {
    var src = mainImg ? (mainImg.dataset.inspectSrc || mainImg.src) : '';
    lbImg.src = src;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  function close() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
  }

  openBtn.addEventListener('click', open);
  lightbox.querySelectorAll('[data-close-inspect]').forEach(function (el) {
    el.addEventListener('click', close);
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !lightbox.hidden) close();
  });
}());
</script>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
