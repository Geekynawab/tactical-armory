<section class="category-nav section--sm">
  <div class="container">
    <div class="category-nav__grid">

      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="category-nav__item" {{ block.shopify_attributes }}>
          <span class="category-nav__icon">{{ block.settings.icon }}</span>
          <span class="category-nav__label">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Navigation",
  "tag": "section",
  "max_blocks": 12,
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji icon",
          "default": "⚔️"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Knives"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Navigation",
      "blocks": [
        { "type": "category", "settings": { "icon": "⚔️", "label": "Knives" } },
        { "type": "category", "settings": { "icon": "🔫", "label": "Gun Models" } },
        { "type": "category", "settings": { "icon": "🗝️", "label": "Keychains" } },
        { "type": "category", "settings": { "icon": "👕", "label": "Apparel" } },
        { "type": "category", "settings": { "icon": "🖱️", "label": "Mousepads" } },
        { "type": "category", "settings": { "icon": "🎁", "label": "Bundles" } },
        { "type": "category", "settings": { "icon": "🏷️", "label": "Sale" } }
      ]
    }
  ]
}
{% endschema %}
