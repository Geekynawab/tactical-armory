<section class="section weapon-categories">
  <div class="container">

    <!-- Row 1: All Guns -->
    <div class="wc-group">
      <div class="wc-group__header">
        <span class="wc-group__label">ALL GUNS</span>
        <span class="wc-group__line"></span>
      </div>

      <!-- All guns — single row -->
      <div class="wc-group__grid wc-group__grid--guns">

        <a href="/collections/vandal" class="wc-item wc-item--rifle wc-item--vandal">
          <div class="wc-item__icon">
            <img src="{{ 'vandal-silhouette.png' | asset_url }}" alt="Vandal" style="width:100%;height:100%;object-fit:contain;filter:invert(1);mix-blend-mode:screen;transform:scaleX(-1);">
          </div>
          <span class="wc-item__name">Vandal</span>
        </a>

        <a href="/collections/phantom" class="wc-item wc-item--rifle wc-item--phantom">
          <div class="wc-item__icon">
            <img src="{{ 'phantom-silhouette.jpeg' | asset_url }}" alt="Phantom" style="width:100%;height:100%;object-fit:contain;filter:invert(1);mix-blend-mode:screen;transform:scaleX(-1);">
          </div>
          <span class="wc-item__name">Phantom</span>
        </a>

        <a href="/collections/sheriff" class="wc-item wc-item--pistol wc-item--sheriff">
          <div class="wc-item__icon">
            <img src="{{ 'sheriff-silhouette.png' | asset_url }}" alt="Sheriff" style="width:100%;height:100%;object-fit:contain;filter:invert(1);mix-blend-mode:screen;transform:scaleX(-1);">
          </div>
          <span class="wc-item__name">Sheriff</span>
        </a>

        <a href="/collections/classic" class="wc-item wc-item--pistol wc-item--classic">
          <div class="wc-item__icon">
            <img src="{{ 'classic-silhouette.png' | asset_url }}" alt="Classic" style="width:100%;height:100%;object-fit:contain;filter:invert(1);mix-blend-mode:screen;transform:scaleX(-1);">
          </div>
          <span class="wc-item__name">Classic</span>
        </a>

        <a href="/collections/spectre" class="wc-item wc-item--smg wc-item--spectre">
          <div class="wc-item__icon">
            <img src="{{ 'spectre-silhouette.png' | asset_url }}" alt="Spectre" style="width:100%;height:100%;object-fit:contain;filter:invert(1);mix-blend-mode:screen;transform:scaleX(-1);">
          </div>
          <span class="wc-item__name">Spectre</span>
        </a>

        <a href="/collections/guardian" class="wc-item wc-item--rifle wc-item--guardian">
          <div class="wc-item__icon">
            <img src="{{ 'guardian-silhouette.jpeg' | asset_url }}" alt="Guardian" style="width:100%;height:100%;object-fit:contain;filter:invert(1);mix-blend-mode:screen;transform:scaleX(-1);">
          </div>
          <span class="wc-item__name">Guardian</span>
          <span class="wc-item__type">RIFLE</span>
        </a>

      </div>
    </div>

    <!-- Row 2: Melee -->
    <div class="wc-group">
      <div class="wc-group__header">
        <span class="wc-group__label">MELEE</span>
        <span class="wc-group__line"></span>
      </div>
      <div class="wc-group__grid">

        <!-- Butterfly Knife: two fanned handles + blade -->
        <a href="/collections/butterfly-knife" class="wc-item wc-item--melee">
          <div class="wc-item__icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M5 18 L18 13 L19 16 L6 21Z" fill="currentColor" opacity="0.8"/>
              <path d="M5 22 L18 27 L19 24 L6 19Z" fill="currentColor" opacity="0.8"/>
              <path d="M18 18 L37 19.5 L18 22Z" fill="currentColor"/>
              <circle cx="37" cy="19.5" r="1.5" fill="var(--color-accent)"/>
            </svg>
          </div>
          <span class="wc-item__name">Butterfly Knife</span>
          <span class="wc-item__type">8 ITEMS</span>
        </a>

        <!-- Knife & Dagger: diagonal double-edge blade + guard -->
        <a href="/collections/knife-dagger" class="wc-item wc-item--melee">
          <div class="wc-item__icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M8 34 L10 32 L30 10 L28 8 L26 10 L8 32Z" fill="currentColor" opacity="0.9"/>
              <rect x="18" y="19" width="8" height="2.5" rx="1" fill="currentColor" opacity="0.65" transform="rotate(45 22 20)"/>
              <circle cx="29" cy="9" r="2" fill="var(--color-accent)"/>
            </svg>
          </div>
          <span class="wc-item__name">Knife & Dagger</span>
          <span class="wc-item__type">9 ITEMS</span>
        </a>

        <!-- Karambit: curved hook blade + finger ring -->
        <a href="/collections/karambit" class="wc-item wc-item--melee">
          <div class="wc-item__icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 30 Q8 14 24 12 Q36 12 36 22 Q36 32 26 32" stroke="currentColor" stroke-width="3.5" fill="none" stroke-linecap="round"/>
              <circle cx="10" cy="30" r="5" fill="none" stroke="currentColor" stroke-width="2" opacity="0.7"/>
              <circle cx="26" cy="32" r="2" fill="var(--color-accent)"/>
            </svg>
          </div>
          <span class="wc-item__name">Karambit</span>
          <span class="wc-item__type">5 ITEMS</span>
        </a>

        <!-- Axe: handle + wedge head -->
        <a href="/collections/axe" class="wc-item wc-item--melee">
          <div class="wc-item__icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="16" y="4" width="3.5" height="32" rx="1.5" fill="currentColor" opacity="0.7"/>
              <path d="M19.5 7 Q32 9 32 20 Q32 29 19.5 32Z" fill="currentColor" opacity="0.9"/>
              <circle cx="32" cy="20" r="2" fill="var(--color-accent)"/>
            </svg>
          </div>
          <span class="wc-item__name">Axe</span>
          <span class="wc-item__type">2 ITEMS</span>
        </a>

        <!-- Sword & Katana: long diagonal blade + tsuba guard -->
        <a href="/collections/sword-katana" class="wc-item wc-item--melee">
          <div class="wc-item__icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M5 35 Q20 28 34 5" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" fill="none"/>
              <path d="M7 33 Q21 27 33 6" stroke="white" stroke-width="0.75" opacity="0.2" fill="none"/>
              <ellipse cx="12" cy="28" rx="5" ry="2" fill="currentColor" opacity="0.65" transform="rotate(-55 12 28)"/>
              <circle cx="34" cy="5" r="2" fill="var(--color-accent)"/>
            </svg>
          </div>
          <span class="wc-item__name">Sword & Katana</span>
          <span class="wc-item__type">2 ITEMS</span>
        </a>

        <!-- Claws & Dual Blades: knuckle grip + three spreading claws -->
        <a href="/collections/claws-dual-blades" class="wc-item wc-item--melee">
          <div class="wc-item__icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="12" y="22" width="16" height="9" rx="2" fill="currentColor" opacity="0.75"/>
              <path d="M15 22 L9 6" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <path d="M20 22 L20 4" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <path d="M25 22 L31 6" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <circle cx="9" cy="6" r="2" fill="var(--color-accent)"/>
              <circle cx="20" cy="4" r="2" fill="var(--color-accent)"/>
              <circle cx="31" cy="6" r="2" fill="var(--color-accent)"/>
            </svg>
          </div>
          <span class="wc-item__name">Claws & Dual Blades</span>
          <span class="wc-item__type">2 ITEMS</span>
        </a>

      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Weapon Categories",
  "tag": "section",
  "settings": [],
  "presets": [
    { "name": "Weapon Categories" }
  ]
}
{% endschema %}
