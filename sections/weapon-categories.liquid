<section class="section weapon-categories">
  <div class="container">

    <!-- Row 1: All Guns -->
    <div class="wc-group">
      <div class="wc-group__header">
        <span class="wc-group__label">ALL GUNS</span>
        <span class="wc-group__line"></span>
      </div>
      <div class="wc-group__grid">

        {%- assign guns = "Classic,Shorty,Frenzy,Ghost,Sheriff,Stinger,Spectre,Bucky,Judge,Bulldog,Guardian,Phantom,Vandal,Marshal,Operator,Ares,Odin" | split: "," -%}
        {%- assign gun_icons = "C,S,F,G,S,S,S,B,J,B,G,P,V,M,O,A,O" | split: "," -%}
        {%- assign gun_types = "pistol,pistol,pistol,pistol,pistol,smg,smg,shotgun,shotgun,rifle,rifle,rifle,rifle,sniper,sniper,lmg,lmg" | split: "," -%}

        {%- for gun in guns -%}
          {%- assign slug = gun | downcase | replace: ' ', '-' -%}
          <a href="/collections/{{ slug }}" class="wc-item wc-item--{{ gun_types[forloop.index0] }}">
            <div class="wc-item__icon">
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="4" y="14" width="28" height="8" rx="1" fill="currentColor" opacity="0.9"/>
                <rect x="28" y="12" width="8" height="4" rx="0.5" fill="currentColor" opacity="0.7"/>
                <rect x="10" y="22" width="6" height="8" rx="1" fill="currentColor" opacity="0.6"/>
                <circle cx="8" cy="18" r="2" fill="var(--color-accent)" opacity="0.8"/>
              </svg>
            </div>
            <span class="wc-item__name">{{ gun }}</span>
            <span class="wc-item__type">{{ gun_types[forloop.index0] | upcase }}</span>
          </a>
        {%- endfor -%}

      </div>
    </div>

    <!-- Row 2: Melee -->
    <div class="wc-group">
      <div class="wc-group__header">
        <span class="wc-group__label">MELEE</span>
        <span class="wc-group__line"></span>
      </div>
      <div class="wc-group__grid">

        {%- assign melees = "Karambit,Butterfly,M9 Bayonet,Stiletto,Huntsman,Bowie,Gut,Talon,Kunai,Skeleton,Shadow Daggers,Ursus,Navaja,Falchion,Flip,Classic Knife" | split: "," -%}

        {%- for melee in melees -%}
          {%- assign slug = melee | downcase | replace: ' ', '-' -%}
          <a href="/collections/{{ slug }}" class="wc-item wc-item--melee">
            <div class="wc-item__icon">
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <line x1="8" y1="32" x2="32" y2="8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                <polygon points="32,8 28,12 30,14" fill="currentColor" opacity="0.7"/>
                <rect x="6" y="30" width="6" height="4" rx="1" fill="currentColor" opacity="0.6" transform="rotate(-45 9 32)"/>
                <circle cx="32" cy="8" r="2" fill="var(--color-accent)"/>
              </svg>
            </div>
            <span class="wc-item__name">{{ melee }}</span>
            <span class="wc-item__type">MELEE</span>
          </a>
        {%- endfor -%}

      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Weapon Categories",
  "tag": "section",
  "settings": [],
  "presets": [
    { "name": "Weapon Categories" }
  ]
}
{% endschema %}
