<header class="site-header" role="banner">
  <div class="container">
    <div class="header-inner">

      <!-- Logo -->
      <a href="/" class="site-logo" aria-label="{{ shop.name }} — Home">
        {%- if settings.logo != blank -%}
          <img
            src="{{ settings.logo | image_url: width: settings.logo_width }}"
            alt="{{ shop.name }}"
            width="{{ settings.logo_width }}"
            loading="eager">
        {%- else -%}
          <span>{{ settings.logo_text | default: shop.name | upcase }}</span>
        {%- endif -%}
      </a>

      <!-- Primary navigation (desktop) -->
      <nav class="nav-primary" aria-label="Primary navigation">

        <!-- Knives & Melee -->
        <div class="nav-item">
          <a href="/collections/knives" class="nav-link">
            Knives &amp; Melee
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="mega-menu">
            <a href="/collections/karambit" class="mega-menu__link">Karambit</a>
            <a href="/collections/butterfly-knife" class="mega-menu__link">Butterfly Knife</a>
            <a href="/collections/kunai" class="mega-menu__link">Kunai / Throwing</a>
            <a href="/collections/katana" class="mega-menu__link">Katana / Sword</a>
            <a href="/collections/bayonet" class="mega-menu__link">M9 Bayonet</a>
            <a href="/collections/tactical-knife" class="mega-menu__link">Tactical Knife</a>
          </div>
        </div>

        <!-- By Skin Collection -->
        <div class="nav-item">
          <a href="/collections/all" class="nav-link">
            By Skin
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="mega-menu">
            <a href="/collections/reaver" class="mega-menu__link">Reaver</a>
            <a href="/collections/prime" class="mega-menu__link">Prime</a>
            <a href="/collections/rgx-11z-pro" class="mega-menu__link">RGX 11z Pro</a>
            <a href="/collections/oni" class="mega-menu__link">Oni</a>
            <a href="/collections/champions" class="mega-menu__link">Champions</a>
            <a href="/collections/araxys" class="mega-menu__link">Araxys</a>
            <a href="/collections/evori-dreamwings" class="mega-menu__link">Evori Dreamwings</a>
            <a href="/collections/gaias-vengeance" class="mega-menu__link">Gaia's Vengeance</a>
          </div>
        </div>

        <!-- Gun Models -->
        <div class="nav-item">
          <a href="/collections/gun-models" class="nav-link">
            Gun Models
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="mega-menu">
            <a href="/collections/vandal" class="mega-menu__link">Vandal</a>
            <a href="/collections/phantom" class="mega-menu__link">Phantom</a>
            <a href="/collections/sheriff" class="mega-menu__link">Sheriff</a>
            <a href="/collections/ghost" class="mega-menu__link">Ghost</a>
            <a href="/collections/shorty" class="mega-menu__link">Shorty</a>
          </div>
        </div>

        <!-- Keychains -->
        <div class="nav-item">
          <a href="/collections/keychains" class="nav-link">Keychains</a>
        </div>

        <!-- Apparel -->
        <div class="nav-item">
          <a href="/collections/apparel" class="nav-link">
            Apparel
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="mega-menu">
            <a href="/collections/t-shirts" class="mega-menu__link">T-Shirts</a>
            <a href="/collections/hats" class="mega-menu__link">Hats / Cosplay</a>
            <a href="/collections/deskmats" class="mega-menu__link">Deskmats / Mousepads</a>
          </div>
        </div>

        <!-- Collectibles -->
        <div class="nav-item">
          <a href="/collections/collectibles" class="nav-link">
            Collectibles
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="mega-menu">
            <a href="/collections/figures" class="mega-menu__link">Figures</a>
            <a href="/collections/plush" class="mega-menu__link">Plush</a>
            <a href="/collections/stickers" class="mega-menu__link">Stickers</a>
          </div>
        </div>

        <!-- Bundles -->
        <div class="nav-item">
          <a href="/collections/bundles" class="nav-link nav-link--accent">Bundles</a>
        </div>

      </nav>

      <!-- Header actions -->
      <div class="header-actions">

        <!-- Search -->
        <form class="search-form" action="/search" method="get" role="search">
          <input
            type="search"
            name="q"
            placeholder="{{ 'general.search.placeholder' | t }}"
            aria-label="{{ 'general.search.placeholder' | t }}"
            value="{{ search.terms | escape }}">
          <button type="submit" aria-label="{{ 'general.search.submit' | t }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </button>
        </form>

        <!-- Account -->
        <a href="/account" class="header-icon" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>

        <!-- Cart -->
        <button class="header-icon" data-cart-open aria-label="{{ 'accessibility.open_cart' | t }}" aria-expanded="false">
          {% render 'icon-cart' %}
          <span class="cart-count" aria-live="polite">{{ cart.item_count }}</span>
        </button>

        <!-- Hamburger (mobile) -->
        <button class="hamburger" id="hamburger-btn" aria-label="{{ 'accessibility.open_navigation' | t }}" aria-controls="mobile-nav" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>

      </div>
    </div>
  </div>

  <!-- Mobile navigation -->
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">

    <div class="mobile-nav__item">
      <button class="mobile-nav__link" data-mobile-toggle="mobile-knives">
        Knives &amp; Melee <span class="toggle-icon">+</span>
      </button>
      <div class="mobile-nav__sub" id="mobile-knives">
        <a href="/collections/karambit">Karambit</a>
        <a href="/collections/butterfly-knife">Butterfly Knife</a>
        <a href="/collections/kunai">Kunai / Throwing</a>
        <a href="/collections/katana">Katana / Sword</a>
        <a href="/collections/bayonet">M9 Bayonet</a>
        <a href="/collections/tactical-knife">Tactical Knife</a>
      </div>
    </div>

    <div class="mobile-nav__item">
      <button class="mobile-nav__link" data-mobile-toggle="mobile-skins">
        By Skin Collection <span class="toggle-icon">+</span>
      </button>
      <div class="mobile-nav__sub" id="mobile-skins">
        <a href="/collections/reaver">Reaver</a>
        <a href="/collections/prime">Prime</a>
        <a href="/collections/rgx-11z-pro">RGX 11z Pro</a>
        <a href="/collections/oni">Oni</a>
        <a href="/collections/champions">Champions</a>
        <a href="/collections/araxys">Araxys</a>
      </div>
    </div>

    <div class="mobile-nav__item">
      <a href="/collections/gun-models" class="mobile-nav__link">Gun Models</a>
    </div>

    <div class="mobile-nav__item">
      <a href="/collections/keychains" class="mobile-nav__link">Keychains</a>
    </div>

    <div class="mobile-nav__item">
      <button class="mobile-nav__link" data-mobile-toggle="mobile-apparel">
        Apparel <span class="toggle-icon">+</span>
      </button>
      <div class="mobile-nav__sub" id="mobile-apparel">
        <a href="/collections/t-shirts">T-Shirts</a>
        <a href="/collections/hats">Hats / Cosplay</a>
        <a href="/collections/deskmats">Deskmats / Mousepads</a>
      </div>
    </div>

    <div class="mobile-nav__item">
      <a href="/collections/collectibles" class="mobile-nav__link">Collectibles</a>
    </div>

    <div class="mobile-nav__item">
      <a href="/collections/bundles" class="mobile-nav__link" style="color:var(--color-accent)">Bundles &amp; Packs</a>
    </div>

    <div class="mobile-nav__item">
      <a href="/collections/sale" class="mobile-nav__link" style="color:var(--color-accent)">Sale / Battle Scarred</a>
    </div>

  </nav>

</header>

{% schema %}
{
  "name": "Header",
  "limit": 1,
  "settings": []
}
{% endschema %}
