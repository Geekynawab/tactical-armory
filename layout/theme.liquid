<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0F1923">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {% render 'social-meta-tags' %}

    {{ content_for_header }}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">

    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>

  <body class="template-{{ template.name }} gradient">

    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    {%- sections 'announcement-bar' -%}
    {%- sections 'header' -%}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer' -%}

    <!-- Cart Drawer -->
    <div id="cart-drawer-overlay" class="cart-drawer__overlay" aria-hidden="true"></div>
    <div id="cart-drawer" class="cart-drawer" aria-label="Cart" role="dialog" aria-modal="true">
      <div class="cart-drawer__header">
        <h2 class="cart-drawer__title">Your Arsenal</h2>
        <button class="cart-drawer__close" id="cart-drawer-close" aria-label="Close cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="cart-drawer__body" id="cart-drawer-body">
        <div class="cart-drawer__loading">Loading...</div>
      </div>
      <div class="cart-drawer__footer" id="cart-drawer-footer"></div>
    </div>

    <!-- Age Verification Modal -->
    <div id="age-verify-modal" class="age-verify" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="age-verify-title">
      <div class="age-verify__box">
        <div class="age-verify__logo">⚔</div>
        <h2 id="age-verify-title" class="age-verify__title">Age Verification</h2>
        <p class="age-verify__text">This store sells blade products. You must be 18 or older to enter.</p>
        <div class="age-verify__actions">
          <button class="btn btn--primary" id="age-verify-yes">I am 18 or older</button>
          <a href="https://www.google.com" class="btn btn--ghost">I am under 18</a>
        </div>
        <p class="age-verify__disclaimer">Not affiliated with or endorsed by Riot Games or VALORANT™</p>
      </div>
    </div>

    <!-- Cookie Consent -->
    <div id="cookie-banner" class="cookie-banner" style="display:none;" role="banner">
      <p>We use cookies to enhance your experience. By continuing, you agree to our <a href="/policies/privacy-policy">Privacy Policy</a>.</p>
      <button class="btn btn--sm btn--primary" id="cookie-accept">Accept</button>
    </div>

    {{ 'theme.js' | asset_url | script_tag }}
  </body>
</html>
