{%- liquid
  assign og_title       = page_title | default: shop.name
  assign og_description = page_description | default: shop.description
  assign og_url         = canonical_url | default: request.origin
  assign og_type        = 'website'
  assign og_image       = ''

  if template.name == 'product'
    assign og_title       = product.title | append: ' — ' | append: shop.name
    assign og_description = product.description | strip_html | truncate: 200
    assign og_type        = 'product'
    if product.featured_image
      assign og_image = product.featured_image | image_url: width: 1200
    endif
  elsif template.name == 'collection'
    assign og_title = collection.title | append: ' — ' | append: shop.name
    if collection.description != blank
      assign og_description = collection.description | strip_html | truncate: 200
    endif
    if collection.image
      assign og_image = collection.image | image_url: width: 1200
    endif
  elsif template.name == 'article'
    assign og_title       = article.title | append: ' — ' | append: shop.name
    assign og_description = article.excerpt | default: article.content | strip_html | truncate: 200
    assign og_type        = 'article'
    if article.image
      assign og_image = article.image | image_url: width: 1200
    endif
  endif
-%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
{%- if og_description != blank -%}
  <meta property="og:description" content="{{ og_description | escape }}">
{%- endif -%}
{%- if og_image != blank -%}
  <meta property="og:image" content="https:{{ og_image }}">
  <meta property="og:image:width" content="1200">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
{%- if og_description != blank -%}
  <meta name="twitter:description" content="{{ og_description | escape }}">
{%- endif -%}
{%- if og_image != blank -%}
  <meta name="twitter:image" content="https:{{ og_image }}">
{%- endif -%}

<link rel="canonical" href="{{ og_url }}">
